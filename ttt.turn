-- Setup --
main: !setup; (!turn ~ !player o).

setup: ?setup / (
  !num s(s(z()))
  | !other o x
  | !other x o
).

?setup / ( ?num s(X) | !num X ).
?setup / ( ?num X | (!row X | !col X) ).
-- ?setup / ( ?row A ~ ?col B ~ ![C]cell ~ !foo C).

?setup, >?row A, >?col B / (
  ( ![C]id | !cell C | !cell/row C A | !cell/col C B )
).

?setup; !move a there; !move b there; !move a here; !f.

-- expect 2 results
(?at X Y, ?f) / !z X Y.

exit

?turn / ( !choose to-mark ).
